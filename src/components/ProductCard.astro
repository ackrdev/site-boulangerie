---
interface Props {
  name: string;
  price: string;
  description: string;
  emoji: string;
}

const { name, price, description, emoji } = Astro.props;
---

<article class="bg-[#FEFCF8] rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
  <!-- Placeholder visuel -->
  <div class="h-44 bg-gradient-to-br from-[#F5F0E8] to-[#C9A96E]/20 flex items-center justify-center">
    <span class="text-6xl" aria-hidden="true">{emoji}</span>
  </div>
  <!-- Contenu -->
  <div class="p-5">
    <div class="flex items-start justify-between gap-2 mb-2">
      <h3 style="font-family: 'Playfair Display', Georgia, serif;" class="text-base font-semibold text-[#6B3F1E] leading-snug">
        {name}
      </h3>
      <span class="text-[#C9A96E] font-semibold text-sm whitespace-nowrap">{price}</span>
    </div>
    <p class="text-[#8B5A2B] text-xs leading-relaxed">{description}</p>
  </div>
</article>
