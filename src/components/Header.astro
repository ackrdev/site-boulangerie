---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/produits', label: 'Nos Produits' },
  { href: '/a-propos', label: 'À Propos' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 bg-[#FEFCF8] shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <span class="text-2xl">🌾</span>
        <span style="font-family: 'Playfair Display', Georgia, serif;" class="text-lg font-bold text-[#6B3F1E] leading-tight">
          Boulangerie Dupont
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8">
        {navLinks.map(({ href, label }) => {
          const isActive = href === '/'
            ? currentPath === '/'
            : currentPath.startsWith(href);
          return (
            <a
              href={href}
              class={`text-sm font-medium transition-colors pb-1 ${
                isActive
                  ? 'text-[#C9A96E] border-b-2 border-[#C9A96E]'
                  : 'text-[#6B3F1E] hover:text-[#C9A96E]'
              }`}
            >
              {label}
            </a>
          );
        })}
      </nav>

      <!-- Mobile hamburger (CSS-only) -->
      <div class="md:hidden">
        <input type="checkbox" id="nav-toggle" class="peer sr-only" />
        <label for="nav-toggle" class="cursor-pointer flex flex-col gap-1.5 p-2" aria-label="Menu">
          <span class="block w-6 h-0.5 bg-[#6B3F1E] transition-all peer-checked:rotate-45"></span>
          <span class="block w-6 h-0.5 bg-[#6B3F1E]"></span>
          <span class="block w-6 h-0.5 bg-[#6B3F1E]"></span>
        </label>
      </div>
    </div>
  </div>

  <!-- Mobile nav dropdown -->
  <div id="mobile-nav" class="hidden md:hidden peer-has-[#nav-toggle:checked]:block bg-[#FEFCF8] border-t border-[#C9A96E]/20 px-4 pb-4">
    <nav class="flex flex-col gap-1 pt-2">
      {navLinks.map(({ href, label }) => {
        const isActive = href === '/'
          ? currentPath === '/'
          : currentPath.startsWith(href);
        return (
          <a
            href={href}
            class={`py-2 px-3 rounded-lg text-sm font-medium ${
              isActive
                ? 'bg-[#C9A96E]/10 text-[#C9A96E]'
                : 'text-[#6B3F1E] hover:bg-[#F5F0E8]'
            }`}
          >
            {label}
          </a>
        );
      })}
    </nav>
  </div>
</header>

<script>
  // Toggle mobile nav
  const toggle = document.getElementById('nav-toggle') as HTMLInputElement;
  const mobileNav = document.getElementById('mobile-nav');
  if (toggle && mobileNav) {
    toggle.addEventListener('change', () => {
      mobileNav.classList.toggle('hidden', !toggle.checked);
    });
  }
</script>
