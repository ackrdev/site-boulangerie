---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-[#6B3F1E]">
  <!-- Fond texturé avec gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#6B3F1E] via-[#7a4822] to-[#4a2c12]"></div>

  <!-- Motif décoratif -->
  <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 20% 50%, #C9A96E 1px, transparent 1px), radial-gradient(circle at 80% 20%, #C9A96E 1px, transparent 1px), radial-gradient(circle at 60% 80%, #C9A96E 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- Contenu centré -->
  <div class="relative z-10 text-center px-4 sm:px-6 max-w-4xl mx-auto">
    <!-- Pré-titre -->
    <p class="text-[#C9A96E] text-xs sm:text-sm tracking-widest uppercase mb-6 font-medium">
      Artisan Boulanger · Paris 11e · Depuis 1985
    </p>

    <!-- Titre principal -->
    <h1 style="font-family: 'Playfair Display', Georgia, serif;" class="text-4xl sm:text-6xl md:text-7xl font-bold text-[#FEFCF8] mb-6 leading-tight">
      Boulangerie<br />
      <span class="text-[#C9A96E]">Dupont</span>
    </h1>

    <!-- Slogan -->
    <p class="text-[#F5F0E8]/80 text-lg sm:text-xl md:text-2xl mb-10 italic" style="font-family: 'Playfair Display', Georgia, serif;">
      "Artisan boulanger depuis 1985, nous pétrissons notre passion chaque matin"
    </p>

    <!-- Boutons CTA -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/produits"
        class="inline-block bg-[#C9A96E] text-[#6B3F1E] font-semibold px-8 py-4 rounded-lg hover:bg-[#A8843A] transition-colors text-base shadow-lg"
      >
        Voir nos produits
      </a>
      <a
        href="/contact"
        class="inline-block border-2 border-[#C9A96E] text-[#C9A96E] font-semibold px-8 py-4 rounded-lg hover:bg-[#C9A96E] hover:text-[#6B3F1E] transition-colors text-base"
      >
        Nous trouver
      </a>
    </div>

    <!-- Indicateur de défilement -->
    <div class="mt-16 animate-bounce">
      <a href="#specialites" class="text-[#C9A96E] text-2xl" aria-label="Défiler vers le bas">↓</a>
    </div>
  </div>
</section>
